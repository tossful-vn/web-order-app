# Tossful web-order-app — environment variables.
# Copy to .env.local and fill in. .env*.local is gitignored (never commit secrets).

# --- Supabase (public, shipped to browser) ---
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# --- Supabase service role (server-only, NEVER prefix NEXT_PUBLIC) ---
# Required by the Hybrid v2 phone auth (TSK-127): creates pre-confirmed auth
# users for synthetic emails, resets passwords, and reads/writes phone_otp_pending.
# Without it, /signup and /reset-password fail. Add to Vercel + local .env.local.
# Find it in Supabase dashboard → Project Settings → API → service_role key.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# --- Zalo OA / ZNS OTP (TSK-127.5, TSK-156) ---
# OTP delivery for signup + password reset. While the OA app creds OR the ZNS
# template are UNSET, OTP is STUBBED: the code is printed to the server console
# instead of sent, and verification still runs for real (expiry + attempt
# lockout intact). Set these (Hiếu provisions at developers.zalo.me) to go live.
#
# TSK-156: the OA access_token now AUTO-REFRESHES. It is NOT an env var anymore —
# it lives (with the rotating refresh_token) in public.zalo_oa_tokens and is
# minted on demand via Zalo OAuth v4. Bootstrap the initial row once with
# scripts/seed-zalo-token.ts (see that file's header). app_id is non-secret;
# app_secret is the secret Hiếu adds to Vercel.
ZALO_OA_APP_ID=2389118150159265519
ZALO_OA_APP_SECRET=
ZALO_ZNS_TEMPLATE_ID=
# DEPRECATED (TSK-156) — no longer read; remove once the token row is seeded:
#   ZALO_OA_ACCESS_TOKEN=   (now managed in public.zalo_oa_tokens)
#   ZALO_OA_REFRESH_TOKEN=  (seed via scripts/seed-zalo-token.ts, then rotates in-DB)
