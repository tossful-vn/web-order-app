# Tossful web-order-app — environment variables.
# Copy to .env.local and fill in. .env*.local is gitignored (never commit secrets).

# --- Supabase (public, shipped to browser) ---
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# --- Supabase service role (server-only, NEVER prefix NEXT_PUBLIC) ---
# Required by the Hybrid v2 phone auth (TSK-127): creates pre-confirmed auth
# users for synthetic emails, resets passwords, and reads/writes phone_otp_pending.
# Without it, /signup and /reset-password fail. Add to Vercel + local .env.local.
# Find it in Supabase dashboard → Project Settings → API → service_role key.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# --- iPOS EOD import endpoint (TSK-151) ---
# Bearer secret for POST /api/ipos/import. The nightly EOD job and the one-time
# May backfill send `Authorization: Bearer <EOD_IMPORT_SECRET>`; any other value
# (or none) is rejected with 401, and the route refuses all imports (503) while
# this is unset. Server-only — NEVER prefix NEXT_PUBLIC. Generate a long random
# value (e.g. `openssl rand -hex 32`) and add it to Vercel + local .env.local.
EOD_IMPORT_SECRET=

# --- Zalo OA / ZNS OTP (TSK-127.5) ---
# OTP delivery for signup + password reset. While these are UNSET, OTP is
# STUBBED: the code is printed to the server console instead of sent, and
# verification still runs for real (expiry + attempt lockout intact).
# Set all of these (Hiếu provisions at developers.zalo.me) to send via Zalo ZNS.
ZALO_OA_APP_ID=
ZALO_OA_APP_SECRET=
ZALO_OA_ACCESS_TOKEN=
ZALO_OA_REFRESH_TOKEN=
ZALO_ZNS_OTP_TEMPLATE_ID=
